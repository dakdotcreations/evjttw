// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  sessions  Session[]
  otps      Otp[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Otp {
  id        String   @id @default(cuid())
  code      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Tourism domain ────────────────────────────────────────────────────────────

model Country {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  flagEmoji   String?
  description String?
  imageUrl    String?
  videoUrl    String?
  locations   Location[]
  features    Feature[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Location {
  id          String          @id @default(cuid())
  name        String
  description String?
  countryId   String
  country     Country         @relation(fields: [countryId], references: [id])
  imageUrl    String?
  videoUrl    String?
  steps       ItineraryStep[]
  features    Feature[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([countryId])
}

model Itinerary {
  id             String          @id @default(cuid())
  title          String
  summary        String
  description    String
  fixedPrice     Decimal?
  pricePerPerson Decimal?
  currency       String          @default("USD")
  durationDays   Int
  bestSeasons    String[]
  coverImage     String?
  images         String[]
  published      Boolean         @default(false)
  steps          ItineraryStep[]
  enquiries      BookingEnquiry[]
  features       FeatureItem[]
  tags           ItineraryTag[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ItineraryStep {
  id              String    @id @default(cuid())
  itineraryId     String
  itinerary       Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  stepNumber      Int
  title           String
  description     String
  highlight       String?
  durationText    String
  durationMinutes Int?
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  images          String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([itineraryId])
  @@index([locationId])
}

model BookingEnquiry {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  message     String?
  travelDate  DateTime?
  groupSize   Int?
  createdAt   DateTime  @default(now())

  @@index([itineraryId])
}

model Testimonial {
  id           String        @id @default(cuid())
  clientName   String
  country      String?
  rating       Int           @default(5)
  quote        String
  published    Boolean       @default(false)
  reviewInvite ReviewInvite?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ReviewInvite {
  id            String       @id @default(cuid())
  token         String       @unique @default(uuid())
  note          String?
  used          Boolean      @default(false)
  testimonialId String?      @unique
  testimonial   Testimonial? @relation(fields: [testimonialId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Feature {
  id          String        @id @default(cuid())
  displayName String?
  countryId   String?
  country     Country?      @relation(fields: [countryId], references: [id])
  locationId  String?
  location    Location?     @relation(fields: [locationId], references: [id])
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  items       FeatureItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([countryId])
  @@index([locationId])
}

model FeatureItem {
  id          String    @id @default(cuid())
  featureId   String
  feature     Feature   @relation(fields: [featureId], references: [id], onDelete: Cascade)
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([featureId, itineraryId])
  @@index([featureId])
  @@index([itineraryId])
}

model Tag {
  id          String         @id @default(cuid())
  name        String         @unique
  slug        String         @unique
  itineraries ItineraryTag[]
  createdAt   DateTime       @default(now())
}

model ItineraryTag {
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  itineraryId String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId       String

  @@id([itineraryId, tagId])
}
